# Backend API base URL (used by the dashboard and injected into embed snippets)
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# URL where the widget loader (embed.js) is hosted. Injected as the <script src>
# in the embed snippet users copy. Locally this is the widget dev server; in
# production point it at your CDN, e.g. https://cdn.yourdomain.com/embed.js
NEXT_PUBLIC_WIDGET_SRC=http://localhost:5173/embed.js
