# ----- Core -----
# SQLite is the zero-setup default. For production use Postgres + pgvector, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/chatbot
DATABASE_URL=sqlite:///./chatbot.db

# Secret used to sign dashboard JWTs. CHANGE THIS in production.
SECRET_KEY=dev-insecure-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----- LLM / Embeddings (Gemini) -----
# Leave empty to run fully offline with deterministic local fallbacks (great for dev/demo).
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# Embedding dimension. Gemini text-embedding-004 = 768. Local fallback adapts to this.
EMBEDDING_DIM=768

# ----- Ingestion -----
MAX_CRAWL_PAGES=50
CRAWL_SAME_DOMAIN_ONLY=true
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# ----- RAG -----
RETRIEVAL_TOP_K=5
# grounded = only answer from site/docs; hybrid = fall back to general knowledge
ANSWER_MODE=grounded

# ----- CORS / widget -----
# Comma-separated origins allowed to load the dashboard API. The public chat
# endpoint additionally enforces each bot's own allowed_domains list.
DASHBOARD_ORIGINS=http://localhost:3000

# Per-bot chat rate limit (requests per minute, per visitor IP)
CHAT_RATE_LIMIT_PER_MIN=20
